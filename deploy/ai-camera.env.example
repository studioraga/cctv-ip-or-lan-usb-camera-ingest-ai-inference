# Copy to deploy/ai-camera.env on each node and edit only values that differ.
# Shell syntax: KEY=value, without spaces around '='.

AI_CAMERA_NODE_ROLE=node1
# Leave blank to let scripts use the directory you run them from. Set an absolute path only for systemd overrides.
AI_CAMERA_REPO_ROOT=
AI_CAMERA_VENV_DIR=.venv
AI_CAMERA_INTERFACE=

# Leave IPs empty to auto-discover the primary IPv4 address on each host.
# For a multi-NIC/VLAN host, set AI_CAMERA_INTERFACE or the explicit IP.
AI_CAMERA_NODE1_IP=
AI_CAMERA_NODE2_IP=

AI_CAMERA_NODE1_API_PORT=8080
AI_CAMERA_NODE1_RTP_PORT=5000
AI_CAMERA_CAPTURE_UDP_PORT=5001
AI_CAMERA_NODE1_METRICS_PORT=9101
AI_CAMERA_NODE2_API_PORT=8082

AI_CAMERA_CAMERA_ID=c922_node2_gate
AI_CAMERA_DEVICE=/dev/video0
AI_CAMERA_PROFILE=mjpeg_720p30
AI_CAMERA_TRANSPORT=rtp
AI_CAMERA_ALLOWED_PROFILES=mjpeg_480p30,mjpeg_720p30,mjpeg_720p60
AI_CAMERA_ALLOWED_DEVICES=/dev/video0

AI_CAMERA_DB=data/events/ai_camera.db
AI_CAMERA_MIGRATIONS=migrations
AI_CAMERA_POLICY=configs/runtime/security_policy.yaml
AI_CAMERA_NODES_CONFIG=configs/runtime/nodes.yaml
AI_CAMERA_CLIP_ROOT=data/clips
AI_CAMERA_KEYFRAME_ROOT=data/keyframes
AI_CAMERA_DATASET_ROOT=data/datasets
AI_CAMERA_EVENT_LOG=results/node1/events.jsonl
AI_CAMERA_LATENCY_THRESHOLD_MS=5.0
AI_CAMERA_LATENCY_WINDOW_SAMPLES=120
AI_CAMERA_CAPTURE_MAX_DURATION_SEC=7200
AI_CAMERA_CAPTURE_DEFAULT_DURATION_SEC=60
AI_CAMERA_CAPTURE_DEFAULT_FRAME_STRIDE=1

# Required on Node1 when Node2 cannot be discovered locally.
AI_CAMERA_NODE2_HOST=
AI_CAMERA_NODE2_USER=
AI_CAMERA_NODE2_REMOTE_ROOT=

# Comma-separated CIDRs/IPs permitted to reach Node1 API. Empty means Node1 IP only.
AI_CAMERA_API_CLIENTS=

# Optional Node1 real-model smoke for Step 12 YOLO ONNX validation.
# The startup script can download this automatically with --download-yolo.
AI_CAMERA_MODEL_DIR=models/object_detection
AI_CAMERA_YOLO_MODEL=models/object_detection/yolo11n.onnx
AI_CAMERA_YOLO_MODEL_URL=https://github.com/ultralytics/assets/releases/download/v8.3.0/yolo11n.onnx
AI_CAMERA_YOLO_MODEL_SHA256=


# Step 14 motion-triggered live MP4 stream defaults.
AI_CAMERA_MOTION_STREAM_DURATION_SEC=60
AI_CAMERA_MOTION_STREAM_LIVE_MP4_FPS=15
AI_CAMERA_MOTION_STREAM_LIVE_MP4_WIDTH=640

# Step 15 Node2 YOLO/motion watcher defaults.
# The watcher owns /dev/video0 while idle, releases it before Node1 starts the
# bounded timed_jpeg_udp stream, then reopens it after the session finishes.
AI_CAMERA_NODE2_WATCHER_SAMPLE_FPS=5
AI_CAMERA_NODE2_WATCHER_MOTION_THRESHOLD=12
AI_CAMERA_NODE2_WATCHER_CANDIDATE_WINDOW=5
AI_CAMERA_NODE2_WATCHER_REQUIRED_CONFIRMATIONS=2
AI_CAMERA_NODE2_WATCHER_COOLDOWN_SEC=20
AI_CAMERA_NODE2_WATCHER_REQUIRE_YOLO=1
AI_CAMERA_NODE2_WATCHER_YOLO_MODEL=${AI_CAMERA_YOLO_MODEL}
AI_CAMERA_NODE2_WATCHER_YOLO_INPUT_SIZE=640
AI_CAMERA_NODE2_WATCHER_YOLO_CONFIDENCE=0.45
AI_CAMERA_NODE2_WATCHER_YOLO_IOU=0.45
AI_CAMERA_NODE2_WATCHER_CLASSES=person,bicycle,car,motorcycle,bus,truck,cat,dog,backpack,suitcase
AI_CAMERA_NODE2_WATCHER_MAX_DETECTIONS=20

# Step 16+ production-readiness controls.
# Node1 API RBAC/auth. Lab mode can leave these blank; customer/demo mode should set them.
AI_CAMERA_NODE1_API_TOKEN=
# Format: name:token:role1|role2,name2:token2:viewer
AI_CAMERA_NODE1_API_KEYS=
AI_CAMERA_NODE1_PUBLIC_ENDPOINTS=/health,/metrics
AI_CAMERA_NODE1_ENFORCE_API_CLIENTS=0
# Comma-separated IP/CIDR values, for example: 192.168.29.20/32,192.168.29.188/32,127.0.0.1/32
AI_CAMERA_API_CLIENTS=

# Signed local Node1<->Node2 API calls. Use the same long random value on both nodes.
AI_CAMERA_NODE_API_SIGNING_SECRET=
AI_CAMERA_NODE1_REQUIRE_SIGNED_NODE2=0
AI_CAMERA_NODE2_REQUIRE_SIGNED_CONTROL=0
AI_CAMERA_NODE2_TO_NODE1_API_KEY=

# Model registry/provenance and ONNX Runtime provider selection.
AI_CAMERA_YOLO_MODEL_ID=yolo11n-coco-onnx
AI_CAMERA_YOLO_MODEL_VERSION=
AI_CAMERA_ONNX_EXECUTION_PROVIDER=auto
AI_CAMERA_REQUIRE_MODEL_SHA256=0
AI_CAMERA_NODE2_WATCHER_YOLO_MODEL_ID=node2-watcher-yolo11n-coco-onnx
AI_CAMERA_NODE2_WATCHER_YOLO_MODEL_VERSION=
AI_CAMERA_NODE2_WATCHER_YOLO_MODEL_SHA256=${AI_CAMERA_YOLO_MODEL_SHA256}
AI_CAMERA_NODE2_WATCHER_ONNX_EXECUTION_PROVIDER=auto

# Storage retention/quota for source datasets and MP4 artifacts.
AI_CAMERA_STORAGE_MAX_BYTES=0
AI_CAMERA_STORAGE_MIN_FREE_BYTES=0
AI_CAMERA_STORAGE_RETENTION_DAYS=0
AI_CAMERA_STORAGE_PRUNE_BATCH=50

# Customer-prem observability hardening. Use 0.0.0.0 only when LAN exposure is intended.
AI_CAMERA_OBSERVABILITY_BIND=127.0.0.1
AI_CAMERA_PROMETHEUS_RETENTION=15d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
# Keep enabled so startup resets the existing grafana_storage volume admin password
# to the value above. Set to 0 only if you manage Grafana admin credentials manually.
AI_CAMERA_GRAFANA_SYNC_ADMIN_PASSWORD=1
GF_AUTH_ANONYMOUS_ENABLED=false
GF_SECURITY_ALLOW_EMBEDDING=false

# Multi-camera expansion before Node3/Node4.
# Format per camera: camera_id|source_ip|node2_port|device|profile1+profile2;camera2|...
AI_CAMERA_ADDITIONAL_CAMERAS=
