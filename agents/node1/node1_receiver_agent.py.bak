#!/usr/bin/env python3
"""Node1 receiver + AI orchestration skeleton.

Receives Node2 C922 MJPEG RTP stream through GStreamer/OpenCV, optionally runs an
ONNX Runtime model, and emits JSONL telemetry for observability.
"""
import argparse
import time
import sys
from pathlib import Path
import cv2
import numpy as np

sys.path.append(str(Path(__file__).resolve().parents[1]))
from common.telemetry import JsonlLogger


def build_pipeline(port: int, buffer_size: int) -> str:
    return (
        f'udpsrc port={port} buffer-size={buffer_size} '
        'caps="application/x-rtp,media=video,clock-rate=90000,encoding-name=JPEG,payload=26" ! '
        'queue leaky=downstream max-size-buffers=2 ! '
        'rtpjpegdepay ! jpegdec ! videoconvert ! video/x-raw,format=BGR ! '
        'appsink drop=true sync=false max-buffers=1'
    )


def load_onnx(model_path: str):
    if not model_path:
        return None, None
    try:
        import onnxruntime as ort
        providers = ["CUDAExecutionProvider", "CPUExecutionProvider"]
        session = ort.InferenceSession(model_path, providers=providers)
        input_name = session.get_inputs()[0].name
        return session, input_name
    except Exception as exc:
        print(f"[WARN] ONNX Runtime disabled: {exc}")
        return None, None


def preprocess_for_demo(frame: np.ndarray, size=(224, 224)) -> np.ndarray:
    resized = cv2.resize(frame, size)
    rgb = cv2.cvtColor(resized, cv2.COLOR_BGR2RGB)
    x = rgb.astype(np.float32) / 255.0
    x = np.transpose(x, (2, 0, 1))[None, ...]
    return x


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--port", type=int, default=5000)
    ap.add_argument("--buffer-size", type=int, default=4194304)
    ap.add_argument("--onnx-model", default="", help="Optional ONNX model path")
    ap.add_argument("--display", action="store_true", help="Show GUI window; requires DISPLAY")
    ap.add_argument("--event-log", default="results/node1/events.jsonl")
    ap.add_argument("--warn-fps-below", type=float, default=20.0)
    args = ap.parse_args()

    telemetry = JsonlLogger(args.event_log)
    pipeline = build_pipeline(args.port, args.buffer_size)
    print("[INFO] Opening pipeline:")
    print(pipeline)

    session, input_name = load_onnx(args.onnx_model)
    cap = cv2.VideoCapture(pipeline, cv2.CAP_GSTREAMER)
    if not cap.isOpened():
        telemetry.emit("receiver_error", message="failed_to_open_pipeline", port=args.port)
        print("[ERROR] Failed to open Node2 MJPEG RTP stream")
        return 1

    telemetry.emit("receiver_started", port=args.port, onnx_enabled=bool(session))
    frames = 0
    t0 = time.time()
    last_report = t0

    try:
        while True:
            ok, frame = cap.read()
            if not ok:
                telemetry.emit("frame_receive_warning", message="no_frame")
                time.sleep(0.02)
                continue

            frames += 1
            inference_ms = None
            if session is not None and frames % 5 == 0:
                x = preprocess_for_demo(frame)
                ti = time.time()
                _ = session.run(None, {input_name: x})
                inference_ms = (time.time() - ti) * 1000.0

            now = time.time()
            if now - last_report >= 2.0:
                fps = frames / (now - t0)
                event = {
                    "frames": frames,
                    "fps_avg": round(fps, 2),
                    "frame_shape": list(frame.shape),
                    "inference_ms": round(inference_ms, 3) if inference_ms is not None else None,
                }
                if fps < args.warn_fps_below:
                    telemetry.emit("receiver_fps_warning", **event)
                else:
                    telemetry.emit("receiver_metrics", **event)
                print(f"[INFO] FPS={fps:.2f}, frame={frame.shape}, infer_ms={inference_ms}")
                last_report = now

            if args.display:
                cv2.imshow("Node2 C922 stream on Node1", frame)
                if (cv2.waitKey(1) & 0xFF) == 27:
                    break
    except KeyboardInterrupt:
        print("\n[INFO] Stopped by user")
    finally:
        cap.release()
        if args.display:
            cv2.destroyAllWindows()
        telemetry.emit("receiver_stopped", frames=frames)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
