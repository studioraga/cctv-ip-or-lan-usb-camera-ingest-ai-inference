# Python caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
.venv.backup-*/
venv/
env/

# Node-local deployment environment
deploy/ai-camera.env

# Runtime/generated configs
configs/runtime/*.yml
configs/runtime/*.yaml
!configs/runtime/.gitkeep

# Runtime logs and validation outputs
results/
*.log

# SQLite/runtime DB artifacts
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
data/events/*.db*

# Runtime media/evidence/datasets
data/clips/
data/keyframes/
data/datasets/
*.mp4
*.mkv
*.mjpg
*.avi
*.jpg
*.jpeg
*.png

# Large model/runtime artifacts
*.onnx
*.engine
*.plan

# Docker accidental bind-mount directories created by wrong relative paths
docker/configs/
docker/docker/

# Build artifacts
build/
dist/
*.egg-info/
cpp/**/build/

# Editor/OS
.DS_Store
.vscode/
.idea/

# Local backup files
*.bak
*.back
*.backup
*.backup-*
*.before_*
*_patched.py
*_patched_v2.py
